# Hermes Environment File - Machine Downtime Log
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file - it contains sensitive information

# GitHub token for pushing to GITHUB_REPO
# Get this from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Application Configuration (override defaults as needed)
APP_PORT=8742
LLM_BASE_URL=http://ray-serve-llama.apps.rtp-ai1-ucs.svpod.dc-01.com/v1
LLM_MODEL=/nvidia/nemotron-3-super
LLM_API_KEY=your_llm_api_key_here
LLM_TIMEOUT_SECONDS=15
DB_PATH=/data/downtime.db
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=8
GITHUB_REPO=https://github.com/pl247/team-2
GHCR_IMAGE=ghcr.io/pl247/team-1